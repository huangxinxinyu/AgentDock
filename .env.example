# AgentDock local development configuration.
# Copy to .env.local and replace values locally. Do not commit real secrets.

AGENTDOCK_HTTP_ADDR=:8080
AGENTDOCK_DATABASE_URL=postgres://agentdock:agentdock@localhost:5432/agentdock?sslmode=disable
AGENTDOCK_APP_SECRET=replace-with-local-development-secret
AGENTDOCK_ENCRYPTION_KEY=replace-with-local-development-encryption-key
AGENTDOCK_CORS_ALLOWED_ORIGIN=http://localhost:5173

# Future provider credentials. Not required for Sprint 1.
DAYTONA_API_KEY=
DAYTONA_API_URL=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
